{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bys-groups/group-settings",
	"version": "0.1.0",
	"title": "BYS - Group Settings",
	"category": "custom-blocks",
	"icon": "admin-settings",
	"description": "Edit settings for the currently selected group (rename, etc).",
	"textdomain": "bys",
	"supports": {
		"anchor": true,
		"html": false,
		"spacing": {
			"margin": true
		}
	},
	"keywords": [ "group", "settings", "rename", "dashboard" ],
	"attributes": {
		"blockId": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
